# ===========================
# 打包排除配置（格式同 .gitignore）
# 打包脚本 pack.sh 会读取此文件
# ===========================

# ===========================
# 截图 / 文档图片（非运行时资源）
# ===========================
image/

# ===========================
# AI 工作流（OpenSpec / CodeBuddy / Cursor）
# ===========================
.codebuddy/
.cursor/
.review/
.analysis-archive/
.analysis-cache.md
openspec/
AGENT-PROGRESS.md

# ===========================
# 本地工具脚本
# ===========================
scripts/

# ===========================
# 测试相关
# ===========================
tests/
jest.config.js
package.json
package-lock.json
node_modules/

# ===========================
# 文档 / 非运行时文件
# ===========================
README.md
CHANGELOG.md
DESCRIPTION.md
LICENSE
todo.md
*.log

# ===========================
# 打包产物（避免嵌套打包）
# ===========================
*.zip
*.crx
*.pem

# ===========================
# 图标生成工具
# ===========================
icons/generate_icons.html
icons/generate_icons.ps1

# ===========================
# 编辑器 / 系统文件
# ===========================
.vscode/
.idea/
*.swp
*.swo
*~
Thumbs.db
Desktop.ini
.DS_Store

# ===========================
# Git / GitHub 相关
# ===========================
.git/
.github/
.gitignore

# ===========================
# 打包脚本自身
# ===========================
pack.sh
pack.ps1
.packignore

# ===========================
# 临时文件
# ===========================
*.tmp
*.bak
